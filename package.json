{
  "name": "radar",
  "version": "0.1.0",
  "private": true,
  "description": "RADAR - Plateforme de veille strategique multi-agents (M244)",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "pnpm --filter @radar/database generate",
    "db:migrate": "pnpm --filter @radar/database migrate",
    "db:seed": "pnpm --filter @radar/database seed"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
